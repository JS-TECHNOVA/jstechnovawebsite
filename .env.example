DEBUG=true
SECRET_KEY=replace-with-a-real-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
TIME_ZONE=UTC
SECURE_SSL_REDIRECT=false
RATELIMIT_ENABLE=true
